
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Station {
  id          String   @id
  label       String
  description String   @default("")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("stations")
}

model Order {
  id             Int      @id @default(autoincrement())
  orderNumber    String   @unique @map("order_number")
  customerName   String   @default("") @map("customer_name")
  department     String   @default("")
  currentStation String   @default("basket") @map("current_station")
  status         String   @default("Producible")
  isRush         Boolean  @default(false) @map("is_rush")
  shipDate       String?  @map("ship_date")
  saleAmount     Float    @default(0) @map("sale_amount")
  sidemark       String   @default("")
  notes          String   @default("")
  target         String   @default("")
  sortOrder      Int      @default(0) @map("sort_order")
  deletedAt      String?  @map("deleted_at")
  // Set by autoAdvanceDoneOrders when an order is moved by the timer;
  // cleared when an admin manually changes the station.
  autoAdvancedFrom String? @map("auto_advanced_from")
  autoAdvancedAt   DateTime? @map("auto_advanced_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  stationStatuses OrderStationStatus[]
  auditLogs       AuditLog[]

  @@index([currentStation])
  @@index([status])
  @@index([isRush])
  @@index([shipDate])
  @@index([orderNumber])
  @@map("orders")
}

model OrderStationStatus {
  id             Int       @id @default(autoincrement())
  orderId        Int       @map("order_id")
  station        String
  done           Boolean   @default(false)
  doneAt         String?   @map("done_at")
  hold           Boolean   @default(false)
  holdReason     String    @default("") @map("hold_reason")
  missing        Boolean   @default(false)
  missingDetails String    @default("") @map("missing_details")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, station])
  @@index([orderId])
  @@index([station])
  @@index([doneAt])
  @@map("order_station_status")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  orderId      Int      @map("order_id")
  station      String?
  fieldChanged String   @map("field_changed")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  changedAt    DateTime @default(now()) @map("changed_at")
  changedBy    String   @default("") @map("changed_by")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([changedAt])
  @@map("audit_log")
}

model Settings {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}
